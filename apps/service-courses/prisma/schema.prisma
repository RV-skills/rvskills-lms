generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
    previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
  schemas = ["courses"]
}

enum ContentType {
  VIDEO
  PDF
  LINK
  SLIDE
  QUIZ
  OTHER
}

enum CourseStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ProcessingStatus {
  PENDING
  PROCESSING
  READY
  FAILED
}

model Course {
  course_id String @id @default(uuid())
  tenant_id String  // References Tenant in service-auth — no FK by design
  title String
  description String?
  thumbnail_url String?
  language String @default("en")
  difficulty String @default("beginner")
  status CourseStatus @default(DRAFT)
  is_published Boolean @default(false)
  published_at DateTime?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  deleted_at DateTime?

  faculty CourseFaculty[]
  modules Module[]
}

model CourseFaculty {
  course_id String
  faculty_id String  // References User in service-auth — no FK by design
  role String @default("primary")

  course Course @relation(fields: [course_id], references: [course_id])
  @@id([course_id, faculty_id])
}

model Module {
  module_id String @id @default(uuid())
  course_id String
  title String
  description String?
  order_index Int
  is_locked Boolean @default(false)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  deleted_at DateTime?

  course Course @relation(fields: [course_id], references: [course_id])
  lessons Lesson[]
}

model Lesson {
  lesson_id String @id @default(uuid())
  module_id String
  title String
  content_type ContentType
  order_index Int
  is_preview Boolean @default(false)
  estimated_duration_mins Int?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  deleted_at DateTime?

  module Module @relation(fields: [module_id], references: [module_id])
  content_metadata  ContentMetadata?
}

model ContentMetadata {
  content_id String @id @default(uuid())
  lesson_id String @unique 
  s3_key String
  mime_type String
  file_size Int
  duration_secs Int?
  original_filename String?
  processing_status ProcessingStatus @default(PENDING)
  download_count Int @default(0)
  created_at DateTime @default(now())

  lesson Lesson @relation(fields: [lesson_id], references: [lesson_id])
}

